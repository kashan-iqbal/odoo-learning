<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Tree View -->
  <record id="view_class_tree" model="ir.ui.view">
    <field name="name">school class list</field>
    <field name="model">school.class</field>
    <field name="arch" type="xml">
      <tree>
        <field name="class_name" />
        <field name="status" />

      </tree>
    </field>
  </record>

  <!-- Form View -->
  <record id="view_class_form" model="ir.ui.view">
    <field name="name">school class listing</field>
    <field name="model">school.class</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_active" string="active" type="object" class="btn-primary" />
          <button name="action_inactive" string="inactive" type="object" />
          <field name="status" widget="statusbar" statusbar_visible="active" />
        </header>
        <sheet>
          <group>
            <field name="class_name" />
            <field name="status" />
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_class_name" model="ir.actions.act_window">
    <field name="name">Class</field>
    <field name="res_model">school.class</field>
    <field name="view_mode">tree,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create your first class record
      </p>
    </field>
  </record>
</odoo>