<?xml version="1.0" encoding="UTF-8"?>

<odoo>
  <!-- Tree View -->
  <record id="view_subject_tree" model="ir.ui.view">
    <field name="name">school subject list</field>
    <field name="model">school.subject</field>
    <field name="arch" type="xml">
      <tree>
        <field name="subject_name" />
        <field name="subject_id" />

      </tree>
    </field>
  </record>

  <!-- Form View -->
  <record id="view_subject_form" model="ir.ui.view">
    <field name="name">school subject listing</field>
    <field name="model">school.subject</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="subject_name" />
            <field name="subject_id" />
            <button name="action_test" type="object" string="Test Client" class="btn-secondary">

            </button>

          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_subject_name" model="ir.actions.act_window">
    <field name="name">Subject</field>
    <field name="res_model">school.subject</field>
    <field name="view_mode">tree,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create your first subject record
      </p>
    </field>


  </record>


  <record id='ir_cron_subject' model='ir.cron'>
    <field name='name'>Subject Cron Job</field>
    <field name='model_id' ref='model_school_subject' />
    <field name='state'>code</field>
    <field name='code'>model.cron_job_method()</field>
    <field name='interval_number'>1</field>
    <field name='interval_type'>hours</field>


  </record>
</odoo>