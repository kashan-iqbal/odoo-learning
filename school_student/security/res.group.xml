<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="module_school_student" model="ir.module.category">
    <field name="name">school</field>
    <field name="description">Access rights for student</field>
    <field name="sequence">10</field>
  </record>

  <record id="group_school_admin" model="res.groups">
    <field name="name">School Admin</field>                     <!-- changed -->
    <field name="category_id" ref="module_school_student" />
    <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
  </record>

  <record id="group_school_super" model="res.groups">
    <field name="name">School Super</field>                     <!-- changed -->
    <field name="category_id" ref="module_school_student" />
    <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
  </record>
</odoo>