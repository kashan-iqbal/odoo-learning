<odoo>
  <data>
    <record id="mail_template_Students" model="mail.template">
      <field name="name">Student Creation Template</field>
      <field name="model_id" ref="school_student.model_school_student" />
      <field name="email_from">testing@elete</field>
      <field name="email_to">kashaniqbal33@gmail.com</field>
      <field name="subject">New Information on ${object.name}</field>
      <field name="auto_delete" eval="True" />
      <field name="body_html" type="html">
        <p>Dear ${object.name},</p>
        <p>Your student record has been created successfully.</p>
      </field>
    </record>
  </data>
</odoo>