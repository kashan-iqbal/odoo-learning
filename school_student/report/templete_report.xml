<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- CHILD TEMPLATE -->
    <template id="report_student_card_template">
      <t t-call="web.basic_layout">
        <div class="page">
          <h2>Student Card</h2>

          <p>Name: <span t-esc="doc.name" /></p>
          <p>Roll: <span t-esc="doc.roll_number" /></p>
          <p>Class: <span t-esc="doc.class_name" /></p>
          <p>Age: <span t-esc="doc.age" /></p>
          <p>ID: <span t-esc="doc.unique_id" /></p>

        </div>
      </t>
    </template>

    <!-- MAIN TEMPLATE -->
    <template id="report_school_student">
      <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
          <t t-call="school_student.report_student_card_template">
            <t t-set="doc" t-value="o" />
          </t>
        </t>
      </t>
    </template>

    <!-- REPORT ACTION -->
    <record id="action_report_student_card" model="ir.actions.report">
      <field name="name">Student Card</field>
      <field name="model">school.student</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">school_student.report_school_student</field>
      <field name="report_file">school_student.report_school_student</field>
      <field name="binding_model_id" ref="school_student.model_school_student" />
      <field name="binding_type">report</field>
    </record>

  </data>
</odoo>